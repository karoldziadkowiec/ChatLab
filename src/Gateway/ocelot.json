      "DownstreamHostAndPorts": [{ "Host": "localhost", "Port": 8001 }],
      "UpstreamPathTemplate": "/api/core/chat/stream",
      "UpstreamHttpMethod": ["GET", "OPTIONS"]
    },
    {
      "DownstreamPathTemplate": "/api/core/{everything}",
      "DownstreamScheme": "http",
