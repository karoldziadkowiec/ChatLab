{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/health",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [{ "Host": "localhost", "Port": 8001 }],
      "UpstreamPathTemplate": "/api/core/health",
      "UpstreamHttpMethod": ["GET"]
    },
    {
      "DownstreamPathTemplate": "/api/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [{ "Host": "localhost", "Port": 8001 }],
      "UpstreamPathTemplate": "/api/core/{everything}",
      "UpstreamHttpMethod": ["GET", "POST", "PUT", "DELETE", "OPTIONS"]
    },
    {
      "DownstreamPathTemplate": "/api/rt/{transport}/health",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [{ "Host": "localhost", "Port": 8010 }],
      "UpstreamPathTemplate": "/rt/{transport}/api/health",
      "UpstreamHttpMethod": ["GET"]
    },
    {
      "DownstreamPathTemplate": "/api/rt/transports",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [{ "Host": "localhost", "Port": 8010 }],
      "UpstreamPathTemplate": "/rt/transports",
      "UpstreamHttpMethod": ["GET"]
    },
    {
      "DownstreamPathTemplate": "/api/rt/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [{ "Host": "localhost", "Port": 8010 }],
      "UpstreamPathTemplate": "/rt/{everything}",
      "UpstreamHttpMethod": ["GET", "POST", "PUT", "DELETE", "OPTIONS"]
    },
    {
      "DownstreamPathTemplate": "/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [{ "Host": "localhost", "Port": 8016 }],
      "UpstreamPathTemplate": "/rt/socketio/{everything}",
      "UpstreamHttpMethod": ["GET", "POST", "PUT", "DELETE", "OPTIONS"]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:8000"
  }
}
